# Docker Compose & Server environment variables

# Control plane auth token (auto-generated if empty)
CONTROL_PLANE_TOKEN=

# LLM API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Logging
LOG_LEVEL=info

# URLs
CORS_ORIGIN=http://localhost:80
APP_URL=http://localhost:80

# Ports
API_PORT=3001
APP_PORT=80
