# Docker Compose environment variables
# Copy to .env and customize

# Postgres
PG_USER=postgres
PG_PASSWORD=changeme
PG_DATABASE=swarm_allocator
PG_PORT=5432

# Control plane auth token (auto-generated if empty)
CONTROL_PLANE_TOKEN=

# OpenAI API key (mock mode if empty)
OPENAI_API_KEY=

# Logging
LOG_LEVEL=info

# URLs
CORS_ORIGIN=http://localhost:80
APP_URL=http://localhost:80

# Ports
API_PORT=3001
APP_PORT=80
