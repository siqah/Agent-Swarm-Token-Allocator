# LLM Gateway Configuration
# Copy this file to .env and fill in your values

# OpenAI API key (optional — without it the gateway returns mock responses)
# OPENAI_API_KEY=sk-proj-your-key-here

# PostgreSQL connection string (optional — without it the gateway uses db.json)
# DATABASE_URL=postgres://user:password@localhost:5432/swarm_allocator

# Control plane auth token (optional — auto-generated if not set)
# CONTROL_PLANE_TOKEN=ctrl-your-token-here

# Server port (default: 3001)
# PORT=3001

# Node environment (development | production)
# NODE_ENV=development

# Log level (debug | info | warn | error) — default: info
# LOG_LEVEL=info

# CORS origin (default: * in dev, APP_URL in production)
# CORS_ORIGIN=http://localhost:5173

# App URL (used for CORS in production)
# APP_URL=https://swarm.example.com
