# LLM Gateway Configuration
# Copy this file to .env and fill in your values

# OpenAI API key (optional — without it the gateway returns mock responses)
# OPENAI_API_KEY=sk-proj-your-key-here

# PostgreSQL connection string (optional — without it the gateway uses SQLite at swarm.db)
# DATABASE_URL=postgres://user:password@localhost:5432/swarm_allocator

# Control plane auth token (optional — auto-generated if not set)
# CONTROL_PLANE_TOKEN=ctrl-your-token-here

# Server port (default: 3001)
# PORT=3001

# Node environment (development | production)
# NODE_ENV=development

# Log level (debug | info | warn | error) — default: info
# LOG_LEVEL=info

# CORS origin (default: * in dev, APP_URL in production)
# CORS_ORIGIN=http://localhost:5173

# App URL (used for CORS in production)
# APP_URL=https://swarm.example.com

# OpenAI request timeout in ms (default: 60000)
# OPENAI_TIMEOUT=60000

# LLM Provider API keys (configure at least one for real LLM calls)
# OPENAI_API_KEY=sk-proj-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# GOOGLE_API_KEY=your-google-ai-key
# GROQ_API_KEY=gsk_your-groq-key

# Redis URL for distributed rate limiting (optional — defaults to in-memory)
# REDIS_URL=redis://localhost:6379

# Log format: "json" for structured JSON output (default: plain text)
# LOG_FORMAT=json

# Request log ring buffer size (default: 1000)
# REQUEST_LOG_SIZE=1000

# Semantic cache: similarity threshold (0.0–1.0, default: 0.85)
# CACHE_SIMILARITY_THRESHOLD=0.85
# Max semantic cache entries (default: 500)
# CACHE_MAX_ENTRIES=500
# Exact cache TTL in ms (default: 300000 — 5 min)
# CACHE_EXACT_TTL_MS=300000
# Semantic cache TTL in ms (default: 600000 — 10 min)
# CACHE_SEMANTIC_TTL_MS=600000

# Encryption key for provider API keys at rest (optional — plaintext if unset)
# ENCRYPTION_KEY=your-32-char-encryption-key

# Webhook URL for budget exhaustion alerts (optional — supports Slack webhooks)
# WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# WEBHOOK_SECRET=optional-shared-secret

# Sentry DSN for production error monitoring (optional)
# SENTRY_DSN=https://xxx@sentry.io/yyy

# Maximum prompt length in characters (default: 100000)
# MAX_PROMPT_LENGTH=100000

# PostgreSQL connection pool size (default: 10)
# PG_POOL_SIZE=10

# Per-swarm-key rate limit (requests per minute, default: 60)
# SWARM_KEY_RATE_LIMIT=60
